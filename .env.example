# Application Settings
APP_NAME=AI模拟面试平台
APP_ENV=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./data/interview_mocker.db

# JWT Settings
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis Settings (optional for development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM Settings
OPENAI_API_KEY=sk-bbe1f5542aa9955b9c143a17c644bba5
OPENAI_BASE_URL=https://apis.iflow.cn/v1
LLM_PROVIDER=openai
LLM_MODEL=qwen3-max
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ChromaDB Settings
CHROMA_PERSIST_DIRECTORY=./data/chroma

# MinIO/Storage Settings
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=interview-files
